<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        {% for crumb in breadcrumbs %}
          <li>
            {% if crumb.href %}
              <a href="{{ navRoot }}{{ crumb.href }}" title="{{ crumb.label }}">{{ crumb.label }}</a>
            {% else %}
              <span aria-current="page">{{ crumb.label }}</span>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    </nav>
  </div>
</div>
